    '${table.classComment}导入','${table.moduleName}.${table.businessName}.action.import', '${permissionPrefix}:import', @MENU_TYPE_BUTTON, @ORDER_NUM, @parentId,
#else
    '${table.classComment}导入', '','${permissionPrefix}:import', @MENU_TYPE_BUTTON, @ORDER_NUM, @parentId,
