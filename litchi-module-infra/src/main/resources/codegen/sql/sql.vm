-- -----------------------------------------
SET @MENU_TYPE_MENU = 2;
SET @MENU_TYPE_BUTTON = 3;
SET @MENU_STATUS_NORMAL = 0;

-- -----------------------------------------
-- 菜单 INSERT（use_type = 6）
-- name: ${module}.${business}.menu
-- -----------------------------------------
#if ($isI18n)
INSERT INTO system_menu(
    name, i18n, permission, type, sort, parent_id,
    path, icon, component, status, component_name
)
VALUES (
    '${table.classComment}管理', '${table.moduleName}.${table.businessName}.menu', '', @MENU_TYPE_MENU, @ORDER_NUM, ${table.parentMenuId},
    '${simpleClassName_strikeCase}', '', '${table.moduleName}/${table.businessName}/index', @MENU_STATUS_NORMAL, '${table.className}'
);
SET @parentId = LAST_INSERT_ID();
#else
INSERT INTO system_menu(
    name, permission, type, sort, parent_id,
    path, icon, component, status, component_name
)
VALUES (
    '${table.classComment}管理', '', @MENU_TYPE_MENU, @ORDER_NUM, ${table.parentMenuId},
    '${simpleClassName_strikeCase}', '', '${table.moduleName}/${table.businessName}/index', @MENU_STATUS_NORMAL, '${table.className}'
);
SET @parentId = LAST_INSERT_ID();
#end

-- -----------------------------------------
-- 按钮 INSERT（功能操作）
-- name: ${module}:${business}.action.query|create|update|delete|export|import
-- -----------------------------------------
-- @parentId 已在菜单 INSERT 后立即捕获
#set ($functionNames = $FUNCTION_ZH_NAMES)
#set ($index = 0)
#foreach ($fn in $functionNames)
INSERT INTO system_menu(
    name, i18n, permission, type, sort, parent_id,
    path, icon, component, status
)
VALUES (
#if ($isI18n)
    '${table.classComment}${fn}','${table.moduleName}.${table.businessName}.action.${functionOps.get($index)}', '${permissionPrefix}:${functionOps.get($index)}', @MENU_TYPE_BUTTON, $foreach.count, @parentId,
#else
    '${table.classComment}${fn}','', '${permissionPrefix}:${functionOps.get($index)}', @MENU_TYPE_BUTTON, $foreach.count, @parentId,
#end
    '', '', '', @MENU_STATUS_NORMAL
);
#set ($index = $index + 1)
#end
