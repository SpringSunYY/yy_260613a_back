          return handleTree(data);
        },
        labelField: '${treeNameColumn.javaField}',
        valueField: 'id',
        childrenField: 'children',
        placeholder: $t('ui.placeholder.select', [
          #if($isI18n)
            $t('${i18nModuleType}.${table.businessName}.field.${treeParentColumn.javaField}')
